# storytime: environment variables
#
# Copy this file to .env (gitignored) for local development. For Cloudflare
# Pages production, the four API keys below are set as project secrets via
# `wrangler pages secret put NAME`. The R2_* values are only needed by
# standalone scripts (seed-default-stories), not by the deployed app.

# Anthropic (Claude). Used for story generation.
ANTHROPIC_API_KEY=

# OpenAI. Used only for the moderation endpoint (omni-moderation-latest).
OPENAI_API_KEY=

# Fal.ai. Used for cartoon illustration generation (flux/schnell).
FAL_KEY=

# ElevenLabs. Used for narration audio (Daniel voice).
ELEVENLABS_API_KEY=

# Optional: override the Anthropic model. Defaults to claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override the ElevenLabs voice id. Defaults to Daniel.
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# R2 access for the seed:stories script (S3-compatible API). Create the
# access key in the Cloudflare dashboard under R2 → Manage R2 API Tokens
# with read+write on both story-maker-stories and story-maker-media.
# Not needed for local dev (`wrangler pages dev` uses local R2 emulation).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
