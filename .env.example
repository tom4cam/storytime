# Brennan's Story Maker: environment variables
# Copy this file to .env (gitignored) for local development, or set these as
# site environment variables on Netlify for production.

# Anthropic (Claude). Used for story generation.
ANTHROPIC_API_KEY=

# OpenAI. Used only for the moderation endpoint (omni-moderation-latest).
OPENAI_API_KEY=

# Fal.ai. Used for cartoon illustration generation (flux/schnell).
FAL_KEY=

# ElevenLabs. Used for narration audio (Daniel voice).
ELEVENLABS_API_KEY=

# Optional: override the Anthropic model. Defaults to claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override the ElevenLabs voice id. Defaults to Daniel.
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03oN
