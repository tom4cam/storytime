{
  "name": "storytime-app",
  "private": true,
  "version": "0.1.0",
  "description": "A kid friendly web app for making narrated, illustrated stories.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "wrangler pages dev",
    "build": "npm --workspace apps/web run build",
    "preview": "npm --workspace apps/web run preview",
    "typecheck": "npm --workspace apps/web run typecheck && tsc --noEmit -p functions",
    "deploy": "wrangler pages deploy",
    "seed:stories": "tsx --env-file-if-exists=.env scripts/seed-default-stories.ts",
    "seed:samples": "tsx --env-file-if-exists=.env scripts/seed-voice-samples.ts",
    "revert": "tsx --env-file-if-exists=.env scripts/revert-story.ts",
    "translate:i18n": "tsx --env-file-if-exists=.env scripts/translate-i18n.ts",
    "backfill:system": "tsx --env-file-if-exists=.env scripts/backfill-system-stories.ts",
    "cleanup:media": "tsx --env-file-if-exists=.env scripts/cleanup-orphaned-media.ts",
    "backfill:index-language": "tsx --env-file-if-exists=.env scripts/backfill-index-language.ts",
    "take-ownership": "tsx --env-file-if-exists=.env scripts/take-ownership.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@cloudflare/workers-types": "^4.20260525.1",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1"
  }
}
