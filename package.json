{
  "name": "storytime-app",
  "private": true,
  "version": "0.1.0",
  "description": "A kid friendly web app for making narrated, illustrated stories.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "wrangler pages dev",
    "build": "npm --workspace apps/web run build",
    "preview": "npm --workspace apps/web run preview",
    "typecheck": "npm --workspace apps/web run typecheck && tsc --noEmit -p functions",
    "deploy": "wrangler pages deploy",
    "seed:stories": "tsx scripts/seed-default-stories.ts",
    "seed:samples": "tsx scripts/seed-voice-samples.ts",
    "revert": "tsx scripts/revert-story.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@cloudflare/workers-types": "^4.20260525.1",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1"
  }
}
